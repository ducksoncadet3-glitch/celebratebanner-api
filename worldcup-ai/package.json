{
  "name": "worldcup-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 World Cup AI marketing engine (trend hunter, ad generator, video factory) with multilingual output and human approval queue.",
  "main": "server.js",
  "scripts": {
    "start:server": "node server.js",
    "start:orchestrator": "node orchestrator/master.js",
    "run:once": "node -e \"require('./workflows/content-loop').runOnce().then(r=>console.log(JSON.stringify(r,null,2)))\"",
    "review": "node cli/review.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "smoke": "for f in $(find . -name '*.js' -not -path './node_modules/*'); do node --check \"$f\" || exit 1; done; echo OK"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "openai": "^4.60.0",
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
