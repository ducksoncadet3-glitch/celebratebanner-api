# --- Required ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- HTTP server ---
WCAI_PORT=3100

# --- Orchestrator ---
# Standard cron (5 fields). Default: top of every hour.
WCAI_SCHEDULE=0 * * * *
# Set false to disable the cron loop (HTTP /run still works).
WCAI_SCHEDULE_ENABLED=true
# Set false to skip the first run at boot.
WCAI_RUN_ON_BOOT=true

# --- Model overrides (optional) ---
WCAI_AGENT_MODEL=claude-sonnet-4-6
WCAI_TRANSLATE_MODEL=claude-sonnet-4-6
WCAI_ORCHESTRATOR_MODEL=claude-opus-4-7
WCAI_IMAGE_MODEL=gpt-image-1
WCAI_MAX_TOKENS=4000

# --- Future (Phase 2) — placeholders for swap-in ---
# REDIS_URL=
# DATABASE_URL=
