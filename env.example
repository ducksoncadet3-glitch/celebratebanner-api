# ============================================================
#  BannerCraft – Environment Variables  (.env.example)
#  Copy to .env and fill in your values.
# ============================================================

NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ── Allowed CORS origins (comma-separated) ─────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://bannercraft.com

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# ── Cloudinary ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=XXXXXXXXXXXXXXXXXXXXXX

# ── Email (SendGrid SMTP) ───────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.XXXXXXXXXXXXXXXXXXXX
FROM_EMAIL=orders@bannercraft.com

# ── Admin ───────────────────────────────────────────────────
ADMIN_API_KEY=change-me-to-a-long-random-string

# ── Background assets (Cloudinary URLs) ────────────────────
GRAD_BG_URL=https://res.cloudinary.com/your-cloud/image/upload/v1/bannercraft/assets/grad-bg.jpg
STADIUM_BG_URL=https://res.cloudinary.com/your-cloud/image/upload/v1/bannercraft/assets/stadium-bg.jpg
WEDDING_BG_URL=https://res.cloudinary.com/your-cloud/image/upload/v1/bannercraft/assets/wedding-bg.jpg
ANNIV_BG_URL=https://res.cloudinary.com/your-cloud/image/upload/v1/bannercraft/assets/anniversary-bg.jpg
PETS_BG_URL=https://res.cloudinary.com/your-cloud/image/upload/v1/bannercraft/assets/pets-bg.jpg
